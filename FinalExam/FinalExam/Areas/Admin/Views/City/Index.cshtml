@using FinalExam.Models
@model List<City>
<div>
    <a class="btn btn-primary" asp-controller="City" asp-action="Create">Create</a>

    <table class="table">
        <thead>
            <tr>
                <th scope="col">#</th>
                <th scope="col">Name</th>
                <th scope="col">Delete Status</th>
                <th colspan="3" scope="col">Actions</th>

            </tr>
        </thead>
        <tbody>
            @foreach (City city in Model)
            {
                <tr>
                    <th scope="row">@city.Id</th>
                    <td>@city.Name</td>
                    @if (!city.IsDeleted)
                    {
                        <td class="text-success">Actice</td>
                    }
                    else
                    {
                        <td class="text-danger">Inactive</td>
                    }

                    <td>
                        <a class="btn btn-primary" asp-controller="City" asp-action="Update" asp-route-id="@city.Id">Update</a>
                    </td>

                    <td>
                        @if (!city.IsDeleted)
                        {
                            <form asp-controller="City" asp-action="SoftDelete" asp-route-id="@city.Id">
                                <button class="btn btn-warning">SoftDelete</button>
                            </form>
                        }
                        else
                        {
                            <form asp-controller="City" asp-action="Restore" asp-route-id="@city.Id">
                                <button class="btn btn-success">Restore</button>
                            </form>
                        }
                    </td>


                    @if (User.IsInRole("Admin"))
                    {
                        <td>
                            <form asp-controller="City" asp-action="HardDelete" asp-route-id="@city.Id">
                                <button class="btn btn-danger">HardDelete</button>
                            </form>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>